      "id": 6,
      "targets": [
        {
          "expr": "avg(process_cpu_usage{job=\"moto-compare-app\",instance=~\"$instance\"})",
          "legendFormat": "cpu_usage",
          "refId": "A"
        }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {}, "overrides": []},
