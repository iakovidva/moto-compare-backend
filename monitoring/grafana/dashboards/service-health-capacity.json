      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "id": 5,
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"moto-compare-app\",instance=~\"$instance\",area=\"heap\"}) / clamp_min(sum(jvm_memory_max_bytes{job=\"moto-compare-app\",instance=~\"$instance\",area=\"heap\"}), 1)",
          "legendFormat": "heap_usage_ratio",
          "refId": "A"
        }
      ],
      "title": "Java Heap Usage %",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
