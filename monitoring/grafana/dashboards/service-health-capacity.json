      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"moto-compare-app\",instance=~\"$instance\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=\"moto-compare-app\",instance=~\"$instance\"}[5m])), 0.0001)",
          "legendFormat": "5xx_ratio",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx ratio)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "id": 4,
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"moto-compare-app\",instance=~\"$instance\",area=\"heap\"})",
          "legendFormat": "heap_used_bytes",
          "refId": "A"
        }
      ],
      "title": "Java Heap Used",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
