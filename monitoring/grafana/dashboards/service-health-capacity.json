      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"moto-compare-app\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "rps",
          "refId": "A"
        }
      ],
      "title": "Application Throughput (RPS)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"moto-compare-app\",instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "Request Latency p95 (s)",
      "type": "timeseries"
